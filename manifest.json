{
  "manifest_version": 3,
  "name": "Tab Sorter",
  "version": "1.0",
  "description": "Sort tabs by website domain and subdomain on demand",
  "icons": {
    "48": "icons/icon.svg"
  },
  "action": {
    "default_icon": "icons/icon.svg",
    "default_title": "Sort Tabs"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "tabs"
  ]
}
